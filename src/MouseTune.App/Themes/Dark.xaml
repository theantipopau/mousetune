<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#60A5FA</Color>
    <Color x:Key="AccentHoverColor">#3B82F6</Color>
    <Color x:Key="AccentSoftColor">#162B4F</Color>
    <Color x:Key="TealColor">#5EEAD4</Color>
    <Color x:Key="TealSoftColor">#123A3A</Color>
    <Color x:Key="SuccessColor">#86EFAC</Color>
    <Color x:Key="WarningColor">#FBBF24</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="TealBrush" Color="{StaticResource TealColor}" />
    <SolidColorBrush x:Key="TealSoftBrush" Color="{StaticResource TealSoftColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#111318" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1B1F27" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#202635" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#171A20" />
    <SolidColorBrush x:Key="TextBrush" Color="#F5F7FA" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#AAB3C2" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2E3440" />
    <SolidColorBrush x:Key="SubtleBrush" Color="#252B36" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#141922" />
    <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#162B4F" Offset="0" />
        <GradientStop Color="#123A3A" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
