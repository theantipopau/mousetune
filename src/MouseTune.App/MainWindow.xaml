<Window x:Class="MouseTune.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MouseTune"
        MinWidth="680"
        MinHeight="520"
        Width="680"
        Height="590"
        Icon="images/icon.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18"
                Margin="0,0,0,16">
            <DockPanel LastChildFill="True">
            <Button Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right" />
            <StackPanel HorizontalAlignment="Center">
                <Border Background="#05080D"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,8"
                        HorizontalAlignment="Center">
                    <Image Source="images/logo_header.png"
                           Width="360"
                           Height="74"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True" />
                </Border>
                <TextBlock Text="Generic Bluetooth mouse"
                           Style="{DynamicResource CaptionTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ComboBox ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="CurrentName"
                          Visibility="{Binding HasMultipleDevices, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Margin="0,0,0,12" />

                <Border Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource TealSoftBrush}"
                                BorderBrush="{DynamicResource TealBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="4">
                            <Image Source="images/icon.PNG"
                                   Width="48"
                                   Height="48"
                                   Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Column="2"
                                    Margin="8,0,0,0">
                        <DockPanel LastChildFill="False">
                            <Border Style="{DynamicResource PillBorderStyle}"
                                    DockPanel.Dock="Right">
                                <TextBlock Text="{Binding ConnectionStatus}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12" />
                            </Border>
                            <TextBlock Text="{Binding SelectedDeviceName}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <TextBlock Text="{Binding ConnectionTypeText}"
                                   Style="{DynamicResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ReportedWindowsName, StringFormat=Originally detected as: {0}}"
                                   Style="{DynamicResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding SettingsStateText}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TealBrush}"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{DynamicResource CardBorderStyle}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Device name"
                                   Style="{DynamicResource SectionTitleStyle}" />
                        <TextBlock Text="MouseTune changes the name displayed by this Windows computer where Windows permits it. It does not rewrite the Bluetooth name stored in the mouse firmware."
                                   Style="{DynamicResource CaptionTextStyle}"
                                   Margin="0,4,0,10" />
                        <TextBox Text="{Binding CustomName, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="64" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Apply name"
                                    Command="{Binding ApplyNameCommand}" />
                            <Button Content="Restore detected name"
                                    Command="{Binding RestoreDetectedNameCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource CardBorderStyle}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Sensitivity"
                                   Style="{DynamicResource SectionTitleStyle}" />
                        <TextBlock Text="Effective DPI adjusts Windows pointer sensitivity. It does not change the physical sensor inside the mouse."
                                   Style="{DynamicResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="Windows applies this sensitivity setting system-wide. MouseTune remembers the preferred value for this mouse."
                                   Style="{DynamicResource CaptionTextStyle}"
                                   Margin="0,2,0,12" />

                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,10">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="{Binding EffectiveDpiDisplay}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Text="{Binding WindowsPointerSpeed, StringFormat=Windows pointer speed: {0} / 20}"
                                       DockPanel.Dock="Right"
                                       HorizontalAlignment="Right"
                                       FontWeight="SemiBold" />
                        </DockPanel>
                        </Border>

                        <TextBox Text="{Binding EffectiveDpi, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,10,0,8" />
                        <ComboBox ItemsSource="{Binding DpiPresets}"
                                  SelectedItem="{Binding EffectiveDpi}"
                                  Width="140"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,8" />
                        <Slider Minimum="200"
                                Maximum="6400"
                                TickFrequency="100"
                                IsSnapToTickEnabled="True"
                                Value="{Binding EffectiveDpi, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,2,0,10" />
                        <TextBlock Text="{Binding CurrentWindowsPointerSpeed, StringFormat=Current Windows pointer speed: {0} / 20}"
                                   Style="{DynamicResource CaptionTextStyle}"
                                   Margin="0,0,0,10" />
                        <CheckBox Content="Enhance pointer precision"
                                  IsChecked="{Binding EnhancePointerPrecision}" />
                        <Button Content="Save and apply"
                                Command="{Binding SaveAndApplyCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,14,0,0" />
                        <TextBlock Text="Changes remain active after MouseTune is closed."
                                   Style="{DynamicResource CaptionTextStyle}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <DockPanel Margin="0,14,0,0"
                           LastChildFill="False">
                    <Button Content="Restore settings from before MouseTune"
                            Command="{Binding RestorePreviousSettingsCommand}" />
                    <Button Content="Restore standard Windows defaults"
                            Command="{Binding RestoreWindowsDefaultsCommand}" />
                    <Button Content="Export diagnostics"
                            Command="{Binding ExportDiagnosticsCommand}"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right" />
                </DockPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource SubtleBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,14,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{DynamicResource CaptionTextStyle}"
                       Foreground="{DynamicResource TextBrush}" />
        </Border>
    </Grid>
</Window>
