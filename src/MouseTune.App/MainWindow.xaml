<Window x:Class="MouseTune.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MouseTune"
        MinWidth="720"
        MinHeight="560"
        Width="760"
        Height="640"
        Icon="images/icon.ico"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Background="#05080D"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,5">
                    <Image Source="images/logo_header.png"
                           Width="238"
                           Height="50"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Portable mouse tuning"
                               FontWeight="SemiBold"
                               FontSize="15" />
                    <TextBlock Text="Local alias and persistent Windows pointer settings"
                               Style="{DynamicResource CaptionTextStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme}"
                              Width="96"
                              Margin="0,0,8,0" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ComboBox ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="CurrentName"
                          Visibility="{Binding HasMultipleDevices, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Margin="0,0,0,10" />

                <Border Style="{DynamicResource CardBorderStyle}"
                        Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{DynamicResource TealSoftBrush}"
                                BorderBrush="{DynamicResource TealBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="5"
                                Width="58"
                                Height="58">
                            <Image Source="images/icon.PNG"
                                   Stretch="Uniform" />
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedDeviceName}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding ReportedWindowsName, StringFormat=Windows name: {0}}"
                                       Style="{DynamicResource CaptionTextStyle}"
                                       Margin="0,3,0,0" />
                            <TextBlock Text="{Binding ConnectionTypeText, StringFormat=Connection: {0}}"
                                       Style="{DynamicResource CaptionTextStyle}"
                                       Margin="0,1,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <Border Style="{DynamicResource PillBorderStyle}"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="{Binding ConnectionStatus}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12" />
                            </Border>
                            <TextBlock Text="{Binding SettingsStateText}"
                                       Foreground="{DynamicResource TealBrush}"
                                       FontWeight="SemiBold"
                                       TextAlignment="Right"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{DynamicResource CardBorderStyle}"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Device name"
                                       Style="{DynamicResource SectionTitleStyle}" />
                            <TextBlock Text="Saved inside MouseTune, with a Windows friendly-name attempt where permitted."
                                       Style="{DynamicResource CaptionTextStyle}"
                                       Margin="0,3,0,10" />

                            <TextBox Text="{Binding CustomName, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="64" />

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Apply name"
                                        Command="{Binding ApplyNameCommand}" />
                                <Button Content="Reapply Windows name"
                                        Command="{Binding ReapplyWindowsNameCommand}"
                                        Visibility="{Binding HasSavedAliasDrift, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Content="Restore detected name"
                                        Command="{Binding RestoreDetectedNameCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{DynamicResource CardBorderStyle}"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Sensitivity"
                                       Style="{DynamicResource SectionTitleStyle}" />
                            <TextBlock Text="Effective DPI maps to Windows pointer speed. It does not change physical sensor DPI."
                                       Style="{DynamicResource CaptionTextStyle}"
                                       Margin="0,3,0,10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding EffectiveDpi, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding DpiPresets}"
                                          SelectedItem="{Binding EffectiveDpi}" />
                                <CheckBox Grid.Column="3"
                                          Content="Enhance precision"
                                          IsChecked="{Binding EnhancePointerPrecision}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right" />
                            </Grid>

                            <Slider Minimum="200"
                                    Maximum="6400"
                                    TickFrequency="100"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding EffectiveDpi, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,12,0,8" />

                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding EffectiveDpiDisplay}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding WindowsPointerSpeed, StringFormat=Windows speed: {0} / 20}"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <TextBlock Text="{Binding CurrentWindowsPointerSpeed, StringFormat=Current Windows speed: {0} / 20}"
                                       Style="{DynamicResource CaptionTextStyle}"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{DynamicResource CardBorderStyle}"
                        Padding="14"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Recovery and diagnostics"
                                       Style="{DynamicResource SectionTitleStyle}" />
                            <TextBlock Text="Settings remain active after MouseTune closes. Reset options verify Windows read-back values."
                                       Style="{DynamicResource CaptionTextStyle}"
                                       Margin="0,3,0,0" />
                        </StackPanel>

                        <WrapPanel Grid.Column="1"
                                   HorizontalAlignment="Right">
                            <Button Content="Restore previous"
                                    Command="{Binding RestorePreviousSettingsCommand}" />
                            <Button Content="Restore defaults"
                                    Command="{Binding RestoreWindowsDefaultsCommand}" />
                            <Button Content="Export diagnostics"
                                    Command="{Binding ExportDiagnosticsCommand}"
                                    Margin="0,4,0,4" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource SubtleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="11">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Border>

            <Button Grid.Column="1"
                    Content="Save and apply"
                    Command="{Binding SaveAndApplyCommand}"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    MinWidth="132"
                    Margin="10,0,0,0" />
        </Grid>
    </Grid>
</Window>
